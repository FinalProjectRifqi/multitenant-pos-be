NODE_ENV=local
PORT=3004
LOG_LEVEL=info
LOG_FORMAT=pretty
CORS_ORIGINS_ALLOW=http://localhost:3000
DB_DEBUG=false

BCRYPT_SALT_ROUNDS=12
JWT_SECRET=your-jwt-secret-key-minimum-32-characters
JWT_EXPIRES_IN=1h

LOCAL_DB_HOST=postgresql
LOCAL_DB_PORT=5432
LOCAL_DB_USER=nest_user
LOCAL_DB_PASSWORD=nest_password
LOCAL_DB_NAME=nest_app

DEV_DB_HOST=your-dev-server.example.com
DEV_DB_PORT=5432
DEV_DB_USER=dev_user
DEV_DB_PASSWORD=dev_password
DEV_DB_NAME=nest_app_dev
DEV_DB_SSL=true
DEV_DB_SSL_REJECT_UNAUTHORIZED=true
DEV_DB_SSL_CA=
DEV_DB_SSL_KEY=
DEV_DB_SSL_CERT=

PROD_DB_HOST=prod-db.example.com
PROD_DB_PORT=5432
PROD_DB_USER=prod_user
PROD_DB_PASSWORD=prod_password
PROD_DB_NAME=nest_app_prod
PROD_DB_SSL=true
PROD_DB_SSL_REJECT_UNAUTHORIZED=true
PROD_DB_SSL_CA=
PROD_DB_SSL_KEY=
PROD_DB_SSL_CERT=
PROD_DB_STATEMENT_TIMEOUT=30000
PROD_DB_QUERY_TIMEOUT=60000
PROD_DB_CONNECTION_TIMEOUT=5000
PROD_DB_POOL_MIN=2
PROD_DB_POOL_MAX=20

STORAGE_URL=https://your-project.supabase.co
STORAGE_SECRET_KEYS=your-supabase-storage-secret-key
STORAGE_BUCKET_NAME=uploads
STORAGE_MAX_SIZE_PER_FILE=5MB
